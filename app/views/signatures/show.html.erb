<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Assinar Contrato - <%= @contract.title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">
  <div class="max-w-4xl mx-auto py-8 px-4">
    <!-- Cabeçalho -->
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-blue-900">Let's Go Far</h1>
      <p class="text-gray-600">Assessoria Consultiva de Inglês</p>
    </div>

    <% if flash[:alert] %>
      <div class="mb-4 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <!-- Informações do contrato -->
    <div class="bg-white shadow rounded-lg p-6 mb-6">
      <div class="flex justify-between items-start mb-4">
        <div>
          <h2 class="text-xl font-semibold text-gray-900"><%= @contract.title %></h2>
          <p class="text-gray-500"><%= @contract.contract_number %></p>
        </div>
        <span class="px-3 py-1 text-sm font-semibold rounded-full bg-yellow-100 text-yellow-800">
          Aguardando sua assinatura
        </span>
      </div>
      
      <p class="text-gray-600 mb-2">
        Olá, <strong><%= @signer.name %></strong>! Você foi convidado(a) a assinar este contrato.
      </p>
      
      <% if @contract.expires_at %>
        <p class="text-sm text-gray-500">
          ⏰ Este convite expira em <%= @contract.expires_at.strftime('%d/%m/%Y') %>
        </p>
      <% end %>
    </div>

    <!-- Conteúdo do contrato -->
    <div class="bg-white shadow rounded-lg p-6 mb-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Conteúdo do Contrato</h3>
      <div class="prose max-w-none border rounded-lg p-6 bg-gray-50 max-h-96 overflow-y-auto">
        <%= raw @contract.content_html %>
      </div>
    </div>

    <!-- Formulário de assinatura -->
    <div class="bg-white shadow rounded-lg p-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-4">Assinar Contrato</h3>
      
      <%= form_tag public_sign_path(@signer.sign_token), method: :post, class: 'space-y-4', id: 'sign-form' do %>
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-4">
          <p class="text-sm text-blue-800">
            <strong>Importante:</strong> Ao assinar este contrato, você declara que leu e concorda com todos os termos acima.
            A assinatura eletrônica tem validade jurídica conforme a Medida Provisória 2.200-2/2001.
          </p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            Digite seu nome completo para confirmar *
          </label>
          <input type="text" name="confirmation_name" required
                 placeholder="<%= @signer.name %>"
                 class="block w-full px-4 py-3 border border-gray-300 rounded-md shadow-sm text-lg focus:outline-none focus:ring-blue-500 focus:border-blue-500">
        </div>

        <% if @signer.cpf.present? %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Confirme seu CPF *
            </label>
            <input type="text" name="confirmation_cpf" required
                   placeholder="000.000.000-00"
                   class="block w-full px-4 py-3 border border-gray-300 rounded-md shadow-sm text-lg focus:outline-none focus:ring-blue-500 focus:border-blue-500">
          </div>
        <% end %>

        <div class="flex items-start">
          <input type="checkbox" id="agree" required class="mt-1 h-4 w-4 text-blue-600 border-gray-300 rounded">
          <label for="agree" class="ml-2 text-sm text-gray-700">
            Declaro que li e concordo com todos os termos e condições deste contrato.
          </label>
        </div>

        <div class="flex space-x-4 pt-4">
          <button type="submit" class="flex-1 bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-md font-medium text-lg">
            ✓ Assinar Contrato
          </button>
        </div>
      <% end %>

      <div class="mt-6 pt-6 border-t">
        <p class="text-sm text-gray-500 mb-3">Não concorda com os termos?</p>
        <%= form_tag refuse_contract_path(@signer.sign_token, format: nil).gsub('/sign/', '/sign/').gsub('/refuse', '/refuse'), method: :post, class: 'space-y-3' do %>
          <input type="hidden" name="_method" value="post">
          <textarea name="reason" rows="2" placeholder="Motivo da recusa (opcional)"
                    class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm"></textarea>
          <button type="submit" class="bg-red-100 hover:bg-red-200 text-red-700 px-4 py-2 rounded-md text-sm font-medium"
                  onclick="return confirm('Tem certeza que deseja recusar este contrato?')">
            Recusar Contrato
          </button>
        <% end %>
      </div>
    </div>

    <!-- Footer -->
    <div class="text-center mt-8 text-sm text-gray-500">
      <p>Let's Go Far Ensino de Idiomas LTDA • CNPJ: 53.654.906/0001-96</p>
    </div>
  </div>

  <script>
    // Capturar fingerprint básico
    document.getElementById('sign-form').addEventListener('submit', function(e) {
      const fingerprint = btoa(navigator.userAgent + screen.width + screen.height + new Date().getTimezoneOffset());
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'fingerprint';
      input.value = fingerprint;
      this.appendChild(input);
    });
  </script>
</body>
</html>
