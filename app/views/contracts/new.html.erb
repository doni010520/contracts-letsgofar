<% content_for(:title) { 'Novo Contrato' } %>

<div class="mb-6">
  <%= link_to '← Voltar', contracts_path, class: 'text-blue-600 hover:text-blue-900' %>
</div>

<div class="bg-white shadow rounded-lg p-6">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Novo Contrato</h1>

  <%= form_with model: @contract, local: true, class: 'space-y-6' do |f| %>
    <% if @contract.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
        <ul class="list-disc list-inside">
          <% @contract.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Usar Template</label>
      <select name="template_id" id="template_id" class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500">
        <option value="">-- Selecione um template ou crie do zero --</option>
        <% @templates.each do |template| %>
          <option value="<%= template.id %>"><%= template.name %></option>
        <% end %>
      </select>
    </div>

    <div>
      <label for="contract_title" class="block text-sm font-medium text-gray-700 mb-2">Título do Contrato *</label>
      <%= f.text_field :title, class: 'block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500', required: true %>
    </div>

    <div>
      <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-md font-medium">
        Criar Contrato
      </button>
    </div>
  <% end %>
</div>
