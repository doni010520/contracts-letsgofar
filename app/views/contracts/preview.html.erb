<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= @contract.title %></title>
  <style>
    body {
      font-family: Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      max-width: 800px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    @media print {
      body { padding: 0; }
    }
  </style>
</head>
<body>
  <%= raw @contract.content_html %>
  
  <% if @contract.status == 'signed' %>
    <div style="margin-top: 60px; padding-top: 30px; border-top: 2px solid #1a365d;">
      <h3 style="color: #1a365d;">Assinaturas Eletrônicas</h3>
      <% @contract.contract_signers.signed.each do |signer| %>
        <div style="margin: 20px 0; padding: 15px; background-color: #f0f4f8; border-radius: 8px;">
          <p><strong><%= signer.name %></strong></p>
          <p style="font-size: 14px; color: #666;">
            <%= signer.email %><br>
            Assinado em: <%= signer.signed_at.strftime('%d/%m/%Y às %H:%M') %><br>
            <% if signer.contract_signature %>
              IP: <%= signer.contract_signature.ip_address %><br>
              Hash: <code style="font-size: 11px;"><%= signer.contract_signature.signature_hash %></code>
            <% end %>
          </p>
        </div>
      <% end %>
      
      <p style="font-size: 12px; color: #888; margin-top: 30px;">
        Este documento foi assinado eletronicamente de acordo com a Medida Provisória 2.200-2/2001.<br>
        Hash do documento: <%= @contract.document_hash %>
      </p>
    </div>
  <% end %>
</body>
</html>
