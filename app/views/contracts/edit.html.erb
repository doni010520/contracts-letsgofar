<% content_for(:title) { "Editar: #{@contract.title}" } %>

<div class="mb-6">
  <%= link_to '← Voltar', contract_path(@contract), class: 'text-blue-600 hover:text-blue-900' %>
</div>

<div class="max-w-3xl mx-auto space-y-6">
  <!-- Dados do contrato -->
  <div class="bg-white shadow rounded-lg p-6">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Editar Contrato</h1>

    <%= form_with model: @contract, local: true, class: 'space-y-6' do |f| %>
      <% if @contract.errors.any? %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
          <ul class="list-disc list-inside">
            <% @contract.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <label for="contract_title" class="block text-sm font-medium text-gray-700 mb-2">Título *</label>
        <%= f.text_field :title, class: 'block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500', required: true %>
      </div>

      <!-- Data de início do plano -->
      <div>
        <label for="contract_plan_start_date" class="block text-sm font-medium text-gray-700 mb-2">Data de Início do Plano</label>
        <%
          plan_date_value = ''
          if @contract.plan_start_date.present?
            plan_date_value = @contract.plan_start_date.strftime('%Y-%m-%d')
          elsif @contract.variables&.dig('plan_start_date').present?
            raw = @contract.variables['plan_start_date']
            if raw.include?('/')
              parts = raw.split('/')
              plan_date_value = "#{parts[2]}-#{parts[1]}-#{parts[0]}" if parts.length == 3
            else
              plan_date_value = raw
            end
          end
        %>
        <%= f.date_field :plan_start_date, value: plan_date_value, class: 'block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500' %>
        <p class="mt-1 text-xs text-gray-500">A data de término será calculada automaticamente com base na duração do plano.</p>
      </div>

      <% if @contract.contract_template.present? %>
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
          <h3 class="font-medium text-blue-900 mb-4">Preencher Variáveis</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <% (@contract.contract_template.variable_fields || []).each do |field| %>
                <% 
                  field_key = field['key'] || field[:key]
                  field_label = field['label'] || field[:label]
                  field_type = field['type'] || field[:type]
                  field_required = field['required'] || field[:required]
                  current_value = @contract.variables&.dig(field_key) || ''
                %>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">
                    <%= field_label %>
                    <% if field_required %><span class="text-red-500">*</span><% end %>
                  </label>
                  <% case field_type %>
                  <% when 'select', 'state' %>
                    <select name="contract[variables][<%= field_key %>]" class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm">
                      <option value="">Selecione...</option>
                      <% %w[AC AL AP AM BA CE DF ES GO MA MT MS MG PA PB PR PE PI RJ RN RS RO RR SC SP SE TO].each do |uf| %>
                        <option value="<%= uf %>" <%= 'selected' if current_value == uf %>><%= uf %></option>
                      <% end %>
                    </select>
                  <% when 'date' %>
                    <% 
                      # Converter de DD/MM/YYYY para YYYY-MM-DD (formato do input date)
                      date_value = ''
                      if current_value.present?
                        begin
                          if current_value.include?('/')
                            parts = current_value.split('/')
                            date_value = "#{parts[2]}-#{parts[1]}-#{parts[0]}" if parts.length == 3
                          else
                            date_value = current_value
                          end
                        rescue
                          date_value = current_value
                        end
                      end
                    %>
                    <input type="date" 
                           name="contract[variables][<%= field_key %>]" 
                           value="<%= date_value %>"
                           class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500"
                           data-date-field="true"
                           <%= 'required' if field_required %>>
                  <% when 'currency' %>
                    <%
                      # Formatar valor salvo para exibição
                      currency_display = ''
                      if current_value.present?
                        raw_val = current_value.to_s.gsub(/[^\d,.]/, '')
                        # Se já tem vírgula (formato BR), usar direto
                        if raw_val.include?(',')
                          currency_display = "R$ #{raw_val}"
                        elsif raw_val.include?('.')
                          # Formato com ponto decimal -> trocar para vírgula
                          currency_display = "R$ #{raw_val.gsub('.', ',')}"
                        else
                          # Número inteiro
                          currency_display = "R$ #{raw_val},00"
                        end
                      end
                    %>
                    <input type="text"
                           name="contract[variables][<%= field_key %>]"
                           value="<%= currency_display %>"
                           class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500"
                           data-type="currency"
                           placeholder="R$ 0,00"
                           <%= 'required' if field_required %>>
                  <% when 'number' %>
                    <input type="number"
                           name="contract[variables][<%= field_key %>]"
                           value="<%= current_value %>"
                           class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500"
                           <%= 'required' if field_required %>>
                  <% else %>
                    <%
                      data_mask = case field_type
                        when 'cpf' then '000.000.000-00'
                        when 'phone' then '(00) 00000-0000'
                        when 'cep' then '00000-000'
                        else nil
                      end
                    %>
                    <input type="text"
                           name="contract[variables][<%= field_key %>]"
                           value="<%= current_value %>"
                           class="block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500"
                           <% if data_mask %>data-mask="<%= data_mask %>"<% end %>
                           <%= 'required' if field_required %>>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% else %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Conteúdo HTML</label>
            <%= f.text_area :content_html, rows: 20, class: 'block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm font-mono text-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500' %>
          </div>
        <% end %>

      <div class="flex flex-col sm:flex-row gap-3">
        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-md font-medium">
          Salvar Alterações
        </button>
        <%= link_to 'Cancelar', contract_path(@contract), class: 'bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-md font-medium text-center' %>
      </div>
    <% end %>
  </div>

  <!-- Signatários (abaixo dos dados) -->
  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Signatários</h2>

    <!-- Status dos signatários -->
    <% if @contract.contract_signers.any? %>
      <div class="bg-green-50 border border-green-300 rounded-lg p-4 mb-4">
        <div class="flex items-center space-x-2">
          <span class="text-green-600 text-lg">&#10003;</span>
          <p class="font-medium text-green-900"><%= @contract.contract_signers.count %> signatário(s) adicionado(s) — contrato pronto para envio.</p>
        </div>
      </div>
    <% else %>
      <div class="bg-amber-50 border-2 border-amber-400 rounded-lg p-4 mb-4">
        <div class="flex items-center space-x-2">
          <span class="text-amber-500 text-lg">&#9888;</span>
          <p class="font-semibold text-amber-900">Adicione pelo menos um signatário para poder enviar o contrato.</p>
        </div>
      </div>
    <% end %>

    <!-- Lista de signatários existentes -->
    <% if @contract.contract_signers.any? %>
      <div class="space-y-3 mb-6">
        <% @contract.contract_signers.by_order.each do |signer| %>
          <div class="flex items-center justify-between p-3 border rounded-lg">
            <div>
              <p class="font-medium text-sm"><%= signer.name %></p>
              <p class="text-xs text-gray-500"><%= signer.email %></p>
            </div>
            <%= button_to '×', contract_signer_path(@contract, signer), method: :delete, class: 'text-red-600 hover:text-red-900 font-bold text-xl', data: { confirm: 'Remover signatário?' } %>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Formulário para adicionar -->
    <div class="border-t pt-4">
      <h3 class="text-sm font-medium text-gray-700 mb-3">Adicionar Signatário</h3>
      <%= form_with model: ContractSigner.new, url: contract_signers_path(@contract), local: true do |f| %>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Nome *</label>
            <%= f.text_field :name, required: true, class: 'block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm' %>
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Email *</label>
            <%= f.email_field :email, required: true, class: 'block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm' %>
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">CPF</label>
            <%= f.text_field :cpf, class: 'block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm' %>
          </div>
        </div>
        <button type="submit" class="mt-3 bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded-md text-sm font-medium">
          Adicionar Signatário
        </button>
      <% end %>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Máscaras simples (CPF, telefone, CEP)
  document.querySelectorAll('[data-mask]').forEach(function(input) {
    const mask = input.getAttribute('data-mask');
    
    input.addEventListener('input', function(e) {
      let value = e.target.value.replace(/\D/g, '');
      let result = '';
      let maskIndex = 0;
      
      for (let i = 0; i < value.length && maskIndex < mask.length; i++) {
        while (maskIndex < mask.length && mask[maskIndex] !== '0') {
          result += mask[maskIndex];
          maskIndex++;
        }
        if (maskIndex < mask.length) {
          result += value[i];
          maskIndex++;
        }
      }
      
      e.target.value = result;
    });
  });
  
  // Máscara de moeda (R$ 1.234,56)
  function formatCurrency(value) {
    let digits = value.replace(/\D/g, '');
    if (digits === '') return '';
    let num = (parseInt(digits) / 100).toFixed(2);
    let parts = num.split('.');
    parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    return 'R$ ' + parts[0] + ',' + parts[1];
  }

  document.querySelectorAll('[data-type="currency"]').forEach(function(input) {
    input.addEventListener('input', function(e) {
      e.target.value = formatCurrency(e.target.value);
    });
  });
  
  // Converter datas de YYYY-MM-DD para DD/MM/YYYY ao submeter
  document.querySelector('form').addEventListener('submit', function(e) {
    document.querySelectorAll('[data-date-field="true"]').forEach(function(input) {
      if (input.value) {
        const parts = input.value.split('-');
        if (parts.length === 3) {
          // Criar campo hidden com valor no formato brasileiro
          const hiddenInput = document.createElement('input');
          hiddenInput.type = 'hidden';
          hiddenInput.name = input.name;
          hiddenInput.value = parts[2] + '/' + parts[1] + '/' + parts[0];
          input.form.appendChild(hiddenInput);
          // Desabilitar o campo original para não enviar
          input.disabled = true;
        }
      }
    });
  });
});
</script>
