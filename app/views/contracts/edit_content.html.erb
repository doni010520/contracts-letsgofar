<% content_for(:title) { "Editar Conteúdo: #{@contract.title}" } %>

<!-- Trix Editor -->
<link rel="stylesheet" href="https://unpkg.com/trix@2.1.8/dist/trix.css">
<script src="https://unpkg.com/trix@2.1.8/dist/trix.umd.min.js"></script>

<style>
  trix-editor {
    min-height: 600px;
    font-family: Arial, sans-serif;
    font-size: 14px;
    line-height: 1.6;
    padding: 20px;
    border: 1px solid #d1d5db;
    border-radius: 0 0 0.5rem 0.5rem;
  }
  trix-toolbar {
    border: 1px solid #d1d5db;
    border-bottom: none;
    border-radius: 0.5rem 0.5rem 0 0;
    background: #f9fafb;
    padding: 8px;
  }
  trix-toolbar .trix-button-group {
    border-color: #d1d5db;
    margin-bottom: 0;
  }
  trix-toolbar .trix-button {
    border-bottom: 1px solid #d1d5db;
  }
  /* Esconder botão de upload de arquivo do Trix */
  trix-toolbar .trix-button-group--file-tools {
    display: none;
  }
</style>

<div class="mb-6">
  <%= link_to '← Voltar', contract_path(@contract), class: 'text-blue-600 hover:text-blue-900' %>
</div>

<div class="bg-white shadow rounded-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Editar Conteúdo do Contrato</h1>
    <span class="text-sm text-gray-500"><%= @contract.contract_number %></span>
  </div>

  <%= form_with model: @contract, url: update_content_contract_path(@contract), method: :patch, local: true do |f| %>
    <div class="mb-6">
      <%= f.hidden_field :content_html, id: 'contract_content_hidden' %>
      <trix-editor input="contract_content_hidden" class="trix-content"></trix-editor>
    </div>

    <div class="flex space-x-4">
      <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-md font-medium">
        Salvar Alterações
      </button>
      <%= link_to 'Cancelar', contract_path(@contract), class: 'bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-md font-medium' %>
      <%= link_to 'Visualizar', preview_contract_path(@contract), target: '_blank', class: 'bg-gray-600 hover:bg-gray-700 text-white px-6 py-2 rounded-md font-medium' %>
    </div>
  <% end %>
</div>

<script>
// Desabilitar upload de arquivos no Trix
document.addEventListener('trix-file-accept', function(e) {
  e.preventDefault();
});
</script>
