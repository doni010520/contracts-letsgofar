<% content_for(:title) { @contract.title } %>

<div class="mb-6">
  <%= link_to '← Voltar', contracts_path, class: 'text-blue-600 hover:text-blue-900' %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Coluna principal -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Cabeçalho -->
    <div class="bg-white shadow rounded-lg p-6">
      <div class="flex justify-between items-start">
        <div>
          <h1 class="text-2xl font-bold text-gray-900"><%= @contract.title %></h1>
          <p class="text-gray-500"><%= @contract.contract_number %></p>
        </div>
        <% 
          color_classes = {
            'draft' => 'bg-gray-100 text-gray-800',
            'pending' => 'bg-yellow-100 text-yellow-800',
            'partially_signed' => 'bg-blue-100 text-blue-800',
            'signed' => 'bg-green-100 text-green-800',
            'refused' => 'bg-red-100 text-red-800',
            'expired' => 'bg-orange-100 text-orange-800',
            'cancelled' => 'bg-gray-100 text-gray-800'
          }
        %>
        <span class="px-3 py-1 text-sm font-semibold rounded-full <%= color_classes[@contract.status] %>">
          <%= @contract.status_label %>
        </span>
      </div>

      <!-- Ações -->
      <div class="mt-6 flex flex-wrap gap-2">
        <% if @contract.status == 'draft' %>
          <%= link_to 'Editar', edit_contract_path(@contract), class: 'bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-md text-sm font-medium' %>
        <% end %>
        
        <% if @contract.can_send? %>
          <%= button_to 'Enviar para Assinatura', send_for_signature_contract_path(@contract), method: :post, class: 'bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-md text-sm font-medium', data: { confirm: 'Enviar contrato para assinatura?' } %>
        <% end %>
        
        <%= link_to 'Visualizar', preview_contract_path(@contract), target: '_blank', class: 'bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-md text-sm font-medium' %>
        
        <%= button_to 'Duplicar', duplicate_contract_path(@contract), method: :post, class: 'bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium' %>
        
        <% if @contract.can_cancel? %>
          <%= button_to 'Cancelar', cancel_contract_path(@contract), method: :post, class: 'bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-md text-sm font-medium', data: { confirm: 'Tem certeza que deseja cancelar este contrato?' } %>
        <% end %>
      </div>
    </div>

    <!-- Signatários -->
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Signatários</h2>
      
      <% if @contract.contract_signers.any? %>
        <div class="space-y-4">
          <% @contract.contract_signers.by_order.each do |signer| %>
            <div class="flex items-center justify-between p-4 border rounded-lg">
              <div>
                <p class="font-medium text-gray-900"><%= signer.name %></p>
                <p class="text-sm text-gray-500"><%= signer.email %></p>
                <% if signer.cpf.present? %>
                  <p class="text-sm text-gray-500">CPF: <%= signer.cpf %></p>
                <% end %>
              </div>
              <div class="text-right">
                <% case signer.status %>
                <% when 'pending' %>
                  <span class="px-2 py-1 text-xs font-semibold rounded-full bg-yellow-100 text-yellow-800">Pendente</span>
                  <% if @contract.status == 'pending' %>
                    <div class="mt-2">
                      <%= button_to 'Reenviar Email', resend_email_contract_signer_path(@contract, signer), method: :post, class: 'text-xs text-blue-600 hover:text-blue-900' %>
                    </div>
                  <% end %>
                <% when 'signed' %>
                  <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">Assinado</span>
                  <p class="text-xs text-gray-500 mt-1"><%= signer.signed_at.strftime('%d/%m/%Y %H:%M') %></p>
                <% when 'refused' %>
                  <span class="px-2 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-800">Recusado</span>
                  <p class="text-xs text-gray-500 mt-1"><%= signer.refused_at.strftime('%d/%m/%Y %H:%M') %></p>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500">Nenhum signatário adicionado.</p>
        <% if @contract.status == 'draft' %>
          <%= link_to 'Adicionar signatários', edit_contract_path(@contract), class: 'text-blue-600 hover:text-blue-900 text-sm' %>
        <% end %>
      <% end %>
    </div>

    <!-- Conteúdo do contrato (preview) -->
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Conteúdo do Contrato</h2>
      <div class="prose max-w-none border rounded-lg p-6 bg-gray-50">
        <%= raw @contract.content_html %>
      </div>
    </div>
  </div>

  <!-- Coluna lateral -->
  <div class="space-y-6">
    <!-- Informações -->
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Informações</h2>
      <dl class="space-y-3">
        <div>
          <dt class="text-sm text-gray-500">Criado em</dt>
          <dd class="text-sm font-medium"><%= @contract.created_at.strftime('%d/%m/%Y %H:%M') %></dd>
        </div>
        <% if @contract.sent_at %>
          <div>
            <dt class="text-sm text-gray-500">Enviado em</dt>
            <dd class="text-sm font-medium"><%= @contract.sent_at.strftime('%d/%m/%Y %H:%M') %></dd>
          </div>
        <% end %>
        <% if @contract.expires_at %>
          <div>
            <dt class="text-sm text-gray-500">Expira em</dt>
            <dd class="text-sm font-medium"><%= @contract.expires_at.strftime('%d/%m/%Y') %></dd>
          </div>
        <% end %>
        <% if @contract.signed_at %>
          <div>
            <dt class="text-sm text-gray-500">Concluído em</dt>
            <dd class="text-sm font-medium"><%= @contract.signed_at.strftime('%d/%m/%Y %H:%M') %></dd>
          </div>
        <% end %>
        <% if @contract.document_hash %>
          <div>
            <dt class="text-sm text-gray-500">Hash do documento</dt>
            <dd class="text-xs font-mono break-all"><%= @contract.document_hash %></dd>
          </div>
        <% end %>
      </dl>
    </div>

    <!-- Atividades -->
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Atividades</h2>
      <% if @activities.any? %>
        <div class="space-y-4">
          <% @activities.each do |activity| %>
            <div class="flex items-start space-x-3">
              <span class="text-lg"><%= activity.activity_icon %></span>
              <div>
                <p class="text-sm font-medium"><%= activity.activity_label %></p>
                <p class="text-xs text-gray-500"><%= activity.actor_name %> • <%= activity.created_at.strftime('%d/%m %H:%M') %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">Nenhuma atividade registrada.</p>
      <% end %>
    </div>
  </div>
</div>
