<% content_for(:title) { 'Templates de Contrato' } %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Templates de Contrato</h1>
  <%= link_to 'Novo Template', new_contract_template_path, class: 'bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md font-medium' %>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <% if @templates.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nome</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Descrição</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Contratos</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Ações</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @templates.each do |template| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <div class="text-sm font-medium text-gray-900"><%= template.name %></div>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500">
              <%= truncate(template.description, length: 50) %>
            </td>
            <td class="px-6 py-4">
              <% if template.active? %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Ativo</span>
              <% else %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">Inativo</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500">
              <%= template.contracts.count %>
            </td>
            <td class="px-6 py-4 text-right text-sm font-medium space-x-2">
              <%= link_to 'Preview', preview_contract_template_path(template), target: '_blank', class: 'text-gray-600 hover:text-gray-900' %>
              <%= link_to 'Editar', edit_contract_template_path(template), class: 'text-indigo-600 hover:text-indigo-900' %>
              <%= button_to 'Duplicar', duplicate_contract_template_path(template), method: :post, class: 'text-blue-600 hover:text-blue-900' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center py-12">
      <p class="text-gray-500 mb-4">Nenhum template encontrado.</p>
      <%= link_to 'Criar primeiro template', new_contract_template_path, class: 'text-blue-600 hover:text-blue-900 font-medium' %>
    </div>
  <% end %>
</div>
