<% content_for(:title) { 'Novo Template' } %>

<div class="mb-6">
  <%= link_to '← Voltar', contract_templates_path, class: 'text-blue-600 hover:text-blue-900' %>
</div>

<div class="bg-white shadow rounded-lg p-6">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Novo Template</h1>

  <%= form_with model: @template, url: contract_templates_path, local: true, class: 'space-y-6' do |f| %>
    <% if @template.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
        <ul class="list-disc list-inside">
          <% @template.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Nome *</label>
      <%= f.text_field :name, class: 'block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm', required: true %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Descrição</label>
      <%= f.text_area :description, rows: 2, class: 'block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm' %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Conteúdo HTML *</label>
      <p class="text-sm text-gray-500 mb-2">Use {{nome_variavel}} para criar campos dinâmicos.</p>
      <%= f.text_area :content_html, rows: 25, class: 'block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm font-mono text-sm', required: true %>
    </div>

    <div class="flex items-center">
      <%= f.check_box :active, class: 'h-4 w-4 text-blue-600 border-gray-300 rounded' %>
      <label class="ml-2 text-sm text-gray-700">Template ativo</label>
    </div>

    <div class="flex space-x-4">
      <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-md font-medium">
        Criar Template
      </button>
      <%= link_to 'Cancelar', contract_templates_path, class: 'bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-md font-medium' %>
    </div>
  <% end %>
</div>
