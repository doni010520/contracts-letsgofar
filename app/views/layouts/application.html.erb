<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for(:title) || 'Contratos - Let\'s Go Far' %></title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="bg-gray-100 min-h-screen">
  <% if logged_in? %>
    <nav class="bg-blue-900 text-white shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <div class="flex items-center space-x-8">
            <%= link_to 'Let\'s Go Far - Contratos', contracts_path, class: 'text-xl font-bold' %>
            <div class="hidden md:flex space-x-4">
              <%= link_to 'Contratos', contracts_path, class: 'hover:bg-blue-800 px-3 py-2 rounded-md text-sm font-medium' %>
              <%= link_to 'Templates', contract_templates_path, class: 'hover:bg-blue-800 px-3 py-2 rounded-md text-sm font-medium' %>
            </div>
          </div>
          <div class="flex items-center space-x-4">
            <span class="text-sm"><%= current_user.name %></span>
            <%= button_to 'Sair', logout_path, method: :delete, class: 'bg-blue-700 hover:bg-blue-600 px-3 py-2 rounded-md text-sm font-medium' %>
          </div>
        </div>
      </div>
    </nav>
  <% end %>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <% if flash[:notice] %>
      <div class="mb-4 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative" role="alert">
        <%= flash[:notice] %>
      </div>
    <% end %>
    
    <% if flash[:alert] %>
      <div class="mb-4 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative" role="alert">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= yield %>
  </main>

  <footer class="bg-gray-800 text-gray-400 py-4 mt-8">
    <div class="max-w-7xl mx-auto px-4 text-center text-sm">
      &copy; <%= Time.current.year %> Let's Go Far Ensino de Idiomas LTDA. Sistema de Contratos Eletrônicos.
    </div>
  </footer>
</body>
</html>
