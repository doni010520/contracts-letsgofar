# Configurações do Banco de Dados
DATABASE_HOST=localhost
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=sua_senha_aqui
DATABASE_NAME=contracts_production

# Configurações da Aplicação
APP_HOST=contratos.letsgofar.com.br
APP_PROTOCOL=https
RAILS_ENV=production
RAILS_SERVE_STATIC_FILES=true
SECRET_KEY_BASE=gere_uma_chave_segura_aqui

# Configurações do Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxx
MAIL_FROM=contratos@letsgofar.com.br

# Senha do Admin (primeiro acesso)
ADMIN_PASSWORD=mudar_esta_senha

# Redis (para Sidekiq)
REDIS_URL=redis://localhost:6379/0

# SSL
FORCE_SSL=true
